{
  "name": "@shulex/blogger-operator-cli",
  "version": "0.1.0",
  "description": "CLI for operating the shared Blogger API",
  "type": "module",
  "bin": {
    "blogger": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "blog",
    "blogger",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
